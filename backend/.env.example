NODE_ENV=development
PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/ai-notes-pro
JWT_ACCESS_SECRET=replace_with_strong_secret_32_chars_min
JWT_REFRESH_SECRET=replace_with_strong_secret_32_chars_min
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
GEMINI_API_KEY=
# Optional override if your key supports a specific model.
GEMINI_MODEL=gemini-1.5-flash-latest
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
# Comma-separated browser origins (Next.js). Defaults to localhost:3000.
CORS_ORIGIN=http://localhost:3000,https://your-app.vercel.app
